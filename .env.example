# ═══════════════════════════════════════════════════════════════════════
# ZIP Explorer - Environment Configuration
# Copy this file to .env.local and fill in the values you need.
# All variables are OPTIONAL. The app works fully offline by default.
# ═══════════════════════════════════════════════════════════════════════

# ── Firebase (Optional) ───────────────────────────────────────────────
# Enable Firebase for user authentication and cloud sync of preferences.
# Create a project at https://console.firebase.google.com
#
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Google Drive (Optional) ──────────────────────────────────────────
# Enable Google Drive integration for cloud file storage.
# Create OAuth 2.0 credentials at https://console.cloud.google.com
# Required scopes: https://www.googleapis.com/auth/drive.file
#
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── Dropbox (Optional) ───────────────────────────────────────────────
# Enable Dropbox integration for cloud file storage.
# Create an app at https://www.dropbox.com/developers/apps
#
NEXT_PUBLIC_DROPBOX_APP_KEY=

# ── WebDAV / NAS (Optional) ──────────────────────────────────────────
# Connect to any WebDAV-compatible storage:
#   - OpenNAS, NextCloud, ownCloud, Synology, QNAP
#   - Any server with WebDAV enabled (Apache, Nginx)
#
# Examples:
#   NextCloud:  https://your-nextcloud.com/remote.php/dav/files/username/
#   OpenNAS:    http://192.168.1.100:8080/webdav/
#   Synology:   https://your-nas.com:5006/webdav/
#
NEXT_PUBLIC_WEBDAV_URL=
NEXT_PUBLIC_WEBDAV_USERNAME=
NEXT_PUBLIC_WEBDAV_PASSWORD=

# ── Feature Flags ────────────────────────────────────────────────────
# Toggle features on/off. All default to "true" if not set.
#
# NEXT_PUBLIC_FEATURE_CLOUD_STORAGE=true
# NEXT_PUBLIC_FEATURE_FIREBASE_AUTH=true
# NEXT_PUBLIC_FEATURE_FILE_CONVERTER=true
# NEXT_PUBLIC_FEATURE_IMAGE_ANNOTATION=true
# NEXT_PUBLIC_FEATURE_CODE_EDITOR=true
# NEXT_PUBLIC_FEATURE_MARKDOWN_PREVIEW=true

# ── Limits & Security ───────────────────────────────────────────────
# MAX_ZIP_SIZE_MB=500              # Maximum ZIP file size in MB
# MAX_PREVIEW_SIZE_MB=10           # Maximum file size for previews in MB
# MAX_ENTRY_COUNT=50000            # Maximum entries in a ZIP file
# MAX_EDITOR_FILE_SIZE_MB=5        # Maximum file size for editor in MB

# ── Analytics (Optional) ─────────────────────────────────────────────
# NEXT_PUBLIC_ANALYTICS_ID=        # Google Analytics or Plausible ID
# NEXT_PUBLIC_SENTRY_DSN=          # Sentry error tracking DSN
